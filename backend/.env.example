# ==========================================
# North Barber
# Environment variables example
# ==========================================

# Server
PORT=3000

# Frontend
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=north_barber_db

# Authentication
JWT_SECRET=replace_with_a_secure_secret
JWT_EXPIRES_IN=1d

JWT_RESET_SECRET=replace_with_a_secure_reset_secret
JWT_RESET_EXPIRES_IN=15m

# Email - Brevo SMTP
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your_brevo_smtp_login
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_FROM="North Barber <your_verified_sender@example.com>"
MAIL_ENABLED=false